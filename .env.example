# ═══════════════ 数据库 (Neon PostgreSQL) ═══════════════
# 在 https://neon.tech 免费建库，复制连接字符串
# 格式: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ═══════════════ Redis (Upstash) ═══════════════
# 在 https://upstash.com 免费建 Redis，复制 REST URL + Token
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ═══════════════ Auth ═══════════════
# 生成: openssl rand -hex 32
JWT_SECRET=

# ═══════════════ Encryption ═══════════════
# 生成: openssl rand -hex 16
API_KEY_ENCRYPTION_KEY=

# ═══════════════ 邮件 (Resend) ═══════════════
# https://resend.com → API Keys
RESEND_API_KEY=

# ═══════════════ 站点 ═══════════════
# Vercel 部署后自动获得 *.vercel.app 域名
SITE_DOMAIN=

# ═══════════════ AI 模型平台 ═══════════════
PLATFORM_API_URL=https://api.deepseek.com
PLATFORM_API_KEY=
PLATFORM_MODEL_ID=deepseek-chat

# ═══════════════ 环境 ═══════════════
NODE_ENV=production
